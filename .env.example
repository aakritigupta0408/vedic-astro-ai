# Copy to .env and fill in secrets
# Never commit .env to version control

# ─── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ─── Swiss Ephemeris ───────────────────────────────────────────────────────
# Download from https://www.astro.com/swisseph/
SWISSEPH_PATH=/usr/share/ephe
DEFAULT_AYANAMSHA=lahiri

# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=vedic_astro

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Geocoding ─────────────────────────────────────────────────────────────
# Get free key from https://opencagedata.com/
OPENCAGE_API_KEY=

# ─── Critic threshold ──────────────────────────────────────────────────────
CRITIC_PASS_THRESHOLD=0.75
MAX_REVISION_PASSES=1

# ─── Retrograde dignity rule ────────────────────────────────────────────────
# Options: none | kalidasa | mantreshwar
RETROGRADE_DIGNITY_RULE=none
